# ─────────────────────────────────────────────────────────────
# FILE INI BERNAMA: .env.local
# LETAKKAN DI FOLDER UTAMA PROYEK (SEJAJAR DENGAN package.json)
# JANGAN PERNAH UPLOAD FILE INI KE GITHUB — BERISI DATA RAHASIA
# ─────────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────────
# Dapatkan dari: supabase.com → project kamu → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── ANTHROPIC ─────────────────────────────────────────────────
# Dapatkan dari: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── RESEND (email otomatis) ───────────────────────────────────
# Dapatkan dari: resend.com → API Keys
RESEND_API_KEY=re_...

# ── KONFIGURASI APP ───────────────────────────────────────────
# URL utama app kamu
NEXT_PUBLIC_APP_URL=https://app.mulaiinvest.id

# Email pengirim — harus sudah diverifikasi domain di Resend
RESEND_FROM_EMAIL=Admin@mulaiinvest.id

# Secret untuk keamanan webhook Lynk (buat sendiri, string acak panjang)
LYNK_WEBHOOK_SECRET=buat_string_rahasia_panjang_dan_acak_di_sini

# ─────────────────────────────────────────────────────────────
# SOFT CAP: batas pesan per periode aktif. Ubah angka ini sesuka kamu.
# Pak Andung akan sopan menyarankan istirahat jika melebihi batas ini.
# ─────────────────────────────────────────────────────────────
SOFT_CAP_MESSAGES=180
